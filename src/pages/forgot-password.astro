---
/**
 * forgot-password.astro
 *
 * Página para solicitar link de recuperação de senha.
 */
import Layout from '../layouts/MainLayout.astro';
import '@fontsource/inter';
import '@fontsource/outfit';

// Se já estiver logado, não faz sentido estar aqui
import { supabaseSSR } from '../lib/supabaseSSR';
const supabaseSsr = supabaseSSR(Astro);
const { data: { user } } = await supabaseSsr.auth.getUser();

if (user) {
    return Astro.redirect('/dashboard');
}
---

<Layout title="Recuperar Senha | Main Astro">
    <div class="min-h-screen bg-slate-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8 font-sans">
        <div class="sm:mx-auto sm:w-full sm:max-w-md text-center">
            <h1 class="font-bold text-3xl text-violet-600 font-heading">Main Astro</h1>
            <h2 class="mt-6 text-2xl font-black text-slate-800 tracking-tight">
                Recupere sua conta
            </h2>
            <p class="mt-8 text-center text-xs text-slate-400">
                &copy; {new Date().getFullYear()} Main Astro — Todos os direitos reservados.
            </p>
        </div>

        <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
            <div class="bg-white py-8 px-4 shadow-xl shadow-slate-200/50 sm:rounded-2xl sm:px-10 border border-slate-200">
                <form class="space-y-6" id="recovery-form">
                    <div>
                        <label for="email" class="block text-sm font-semibold text-slate-700">E-mail cadastrado</label>
                        <div class="mt-1">
                            <input id="email" name="email" type="email" autocomplete="email" required 
                                class="appearance-none block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-violet-500 focus:border-violet-500 sm:text-sm transition-all bg-slate-50 focus:bg-white"
                                placeholder="seu@email.com" />
                        </div>
                    </div>

                    <div>
                        <button type="submit" id="submit-btn" 
                            class="w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-lg shadow-violet-500/20 text-sm font-bold text-white bg-violet-600 hover:bg-violet-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-violet-500 transition-all transform hover:scale-[1.01] active:scale-[0.99]">
                            Enviar Link de Recuperação
                        </button>
                    </div>
                </form>

                <div id="status-msg" class="mt-4 p-3 rounded-lg text-xs font-semibold hidden"></div>

                <div class="mt-6 text-center">
                    <a href="/login" class="text-sm font-semibold text-violet-600 hover:text-violet-500">
                        Voltar para o login
                    </a>
                </div>
            </div>
        </div>
    </div>
</Layout>

<style>
    .font-heading {
        font-family: 'Outfit', system-ui, sans-serif;
    }
</style>

<script>
    import { supabase } from '../lib/supabase';

    const recoveryForm = document.getElementById('recovery-form') as HTMLFormElement;
    const statusMsg = document.getElementById('status-msg') as HTMLDivElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    recoveryForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        statusMsg.classList.add('hidden');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Enviando...';

        const formData = new FormData(recoveryForm);
        const email = formData.get('email') as string;

        try {
            const { error } = await supabase.auth.resetPasswordForEmail(email, {
                redirectTo: window.location.origin + '/update-password',
            });

            if (error) {
                statusMsg.textContent = error.message;
                statusMsg.classList.remove('hidden', 'bg-emerald-50', 'text-emerald-700', 'border-emerald-200');
                statusMsg.classList.add('bg-red-50', 'text-red-700', 'border-red-200', 'border');
                submitBtn.disabled = false;
                submitBtn.textContent = 'Enviar Link de Recuperação';
            } else {
                statusMsg.textContent = 'Verifique seu e-mail! Enviamos um link para você.';
                statusMsg.classList.remove('hidden', 'bg-red-50', 'text-red-700', 'border-red-200');
                statusMsg.classList.add('bg-emerald-50', 'text-emerald-700', 'border-emerald-200', 'border');
                recoveryForm.reset();
                submitBtn.textContent = 'E-mail enviado!';
            }
        } catch (err: any) {
            statusMsg.textContent = 'Erro inesperado. Tente novamente.';
            statusMsg.classList.remove('hidden');
            statusMsg.classList.add('bg-red-50', 'text-red-700');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Enviar Link de Recuperação';
        }
    });
</script>
