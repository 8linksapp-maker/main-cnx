---
/**
 * index.astro - Home Page Original do SaaS
 * 
 * Restaurada exatamente como estava: usando o CursoVendasTemplate.
 */

import { readSingleton } from '../utils/singleton-utils';

// Buscar tema ativo (fallback para classic)
const activeThemeId = 'classic';

// Buscar dados do curso-vendas do singleton do tema ativo
const cursoVendasData = await readSingleton('curso-vendas', activeThemeId) || {};

// Importar o template curso-vendas do tema classic
const layoutStyle = 'classic';
const CursoVendasTemplate = (await import(`../themes/${layoutStyle}/curso-vendas.astro`)).default;
---

<CursoVendasTemplate 
    cursoVendasData={cursoVendasData}
    themeId={activeThemeId}
/>
