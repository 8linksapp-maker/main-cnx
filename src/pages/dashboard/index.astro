---
/**
 * dashboard/index.astro
 *
 * Página inicial da área logada do cliente.
 */
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { supabaseSSR } from '../../lib/supabaseSSR';

// Verifica a sessão logada e metadados
const supabase = supabaseSSR(Astro);
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/login');
}

// Resgatar as Integrações da Vercel
const { data: vercelIntegrations, error: integrationsError } = await supabase
    .from('integrations')
    .select('*')
    .eq('user_id', user.id)
    .eq('provider', 'vercel');

let allProjects: any[] = [];
let globalDeployments: any[] = [];
let accountErrors: string[] = [];
let hasVercelIntegration = vercelIntegrations && vercelIntegrations.length > 0;

let totalCustomDomains = 0;
let healthStats = { ready: 0, error: 0, building: 0 };

if (hasVercelIntegration) {
    const fetchPromises = vercelIntegrations!.map(async (integration: any) => {
        try {
            // 1. Busca todos os projetos
            const vRes = await fetch('https://api.vercel.com/v9/projects?limit=100', {
                headers: { "Authorization": `Bearer ${integration.token}` }
            });
            
            // 2. Busca últimos 10 deploys GERAIS da conta
            const depRes = await fetch('https://api.vercel.com/v6/deployments?limit=10', {
                headers: { "Authorization": `Bearer ${integration.token}` }
            });

            if (!vRes.ok) {
                accountErrors.push(`Token inválido ou acesso negado na integração: ${integration.account_name || 'Conta Vercel'}`);
                return { projects: [], deployments: [] };
            }

            const data = await vRes.json();
            const depData = depRes.ok ? await depRes.json() : { deployments: [] };

            // Adicionamos o account_name e id da integração
            const mappedProjects = (data.projects || []).map((p: any) => ({ 
                ...p, 
                _accountName: integration.account_name,
                _integrationId: integration.id
            }));

            const mappedDeployments = (depData.deployments || []).map((d: any) => ({
                ...d,
                _accountName: integration.account_name,
                _integrationId: integration.id
            }));

            return { projects: mappedProjects, deployments: mappedDeployments };
        } catch (e: any) {
             accountErrors.push(`Falha de conexão na integração: ${integration.account_name || 'Conta Vercel'}`);
             return { projects: [], deployments: [] };
        }
    });

    const results = await Promise.all(fetchPromises);
    
    // Mescla tudo de todas as contas Vercel Integradas
    allProjects = results.flatMap(r => r.projects);
    globalDeployments = results.flatMap(r => r.deployments);
    
    // Ordena os deploys globais do mais recente pro mais antigo e pega só os últimos 5
    globalDeployments.sort((a, b) => b.createdAt - a.createdAt);
    globalDeployments = globalDeployments.slice(0, 5);

    // Calcula Estatísticas de Saúde e Domínios
    allProjects.forEach(proj => {
        // Quantos Aliases (Domínios Customizados) existem
        if (proj.alias && Array.isArray(proj.alias)) {
            totalCustomDomains += proj.alias.length;
        }

        // Estatísticas do Último Deploy (Health)
        const state = proj.latestDeployments?.[0]?.readyState;
        if (state === 'READY') healthStats.ready++;
        else if (state === 'ERROR') healthStats.error++;
        else if (state === 'BUILDING' || state === 'QUEUED' || state === 'INITIALIZING') healthStats.building++;
    });
}
---

<DashboardLayout title="Visão Geral | CNX SaaS">
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h2 class="text-3xl font-bold text-slate-900 mb-2">Bem-vindo de volta! 👋</h2>
            <p class="text-slate-600">Confira o resumo das suas ferramentas e sites JAMstack ativos.</p>
        </div>
        <a href="/dashboard/create-site" class="px-5 py-2.5 bg-violet-600 text-white font-semibold rounded-xl hover:bg-violet-700 transition-colors shadow-md shadow-violet-500/20 flex items-center gap-2 w-max">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
            </svg>
            Novo Site
        </a>
    </div>

    {/* Alerta caso o token não exista ou esteja errado */}
    {!hasVercelIntegration && (
        <div class="mb-8 bg-amber-50 border border-amber-200 rounded-2xl p-6 shadow-sm">
            <h3 class="font-bold text-amber-800 text-lg mb-2">Configure sua Nuvem</h3>
            <p class="text-amber-700 mb-4">
                Para visualizar e gerenciar os seus sites aqui na Visão Geral, você precisa vincular uma <strong>Conta da Vercel</strong>.
            </p>
            <a href="/dashboard/settings" class="inline-block px-4 py-2 bg-amber-100 font-semibold text-amber-800 rounded-lg hover:bg-amber-200 transition-colors border border-amber-300">
                Ir para Configurações
            </a>
        </div>
    )}

    {accountErrors.length > 0 && (
        <div class="mb-8 space-y-2">
            {accountErrors.map(err => (
                <div class="bg-red-50 border border-red-200 rounded-2xl p-5 text-red-700 text-sm font-medium">
                    ⚠️ {err}
                </div>
            ))}
        </div>
    )}

    <!-- Painel Mestre de Monitoramento -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <!-- Card 1: Sites Totais -->
        <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden">
            <div class="absolute top-0 right-0 p-4 opacity-5">
                <span class="text-8xl">📦</span>
            </div>
            <div class="w-12 h-12 rounded-xl bg-violet-100 text-violet-600 flex items-center justify-center text-xl mb-4 relative z-10">
                🌐
            </div>
            <h3 class="font-semibold text-lg text-slate-800 mb-1 relative z-10">Total de Sites</h3>
            <p class="text-4xl font-black text-slate-900 mb-2 relative z-10">{hasVercelIntegration ? allProjects.length : '0'}</p>
            {hasVercelIntegration ? (
                <p class="text-sm text-slate-500 font-medium relative z-10">Conectados em {vercelIntegrations!.length} conta(s) Vercel</p>
            ) : (
                <p class="text-sm text-slate-500 relative z-10">Integração Vercel pendente.</p>
            )}
        </div>

        <!-- Card 2: Health Check -->
        <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between mb-4">
                <div class="w-12 h-12 rounded-xl bg-teal-100 text-teal-600 flex items-center justify-center text-xl">
                    🩺
                </div>
                {hasVercelIntegration && (
                    <span class="px-3 py-1 bg-slate-100 text-slate-600 text-xs font-bold rounded-full border border-slate-200">
                        {healthStats.ready + healthStats.error + healthStats.building} Válidos
                    </span>
                )}
            </div>
            <h3 class="font-semibold text-lg text-slate-800 mb-4">Saúde dos Projetos (Health)</h3>
            
            {hasVercelIntegration ? (
                <div class="space-y-3">
                    <div class="flex items-center justify-between text-sm">
                        <span class="flex items-center gap-2 text-slate-600 font-medium">
                            <span class="w-2.5 h-2.5 rounded-full bg-emerald-500"></span> Online (Prontos)
                        </span>
                        <span class="font-bold text-slate-800">{healthStats.ready}</span>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                        <span class="flex items-center gap-2 text-slate-600 font-medium">
                            <span class="w-2.5 h-2.5 rounded-full bg-red-500"></span> Com Erros (Falha)
                        </span>
                        <span class="font-bold text-slate-800">{healthStats.error}</span>
                    </div>
                    <div class="flex items-center justify-between text-sm">
                        <span class="flex items-center gap-2 text-slate-600 font-medium">
                            <span class="w-2.5 h-2.5 rounded-full bg-amber-500"></span> Building (Na Fila)
                        </span>
                        <span class="font-bold text-slate-800">{healthStats.building}</span>
                    </div>
                </div>
            ) : (
                <div class="h-full flex items-center pb-8">
                     <p class="text-sm text-slate-400 font-medium">Métricas indisponíveis</p>
                </div>
            )}
        </div>

        <!-- Card 3: Domínios Registrados -->
        <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden">
             <div class="absolute top-0 right-0 p-4 opacity-5">
                <span class="text-8xl">🔗</span>
            </div>
            <div class="w-12 h-12 rounded-xl bg-blue-100 text-blue-600 flex items-center justify-center text-xl mb-4 relative z-10">
                🌍
            </div>
            <h3 class="font-semibold text-lg text-slate-800 mb-1 relative z-10">Inventário de Domínios</h3>
            <p class="text-4xl font-black text-slate-900 mb-2 relative z-10">{hasVercelIntegration ? totalCustomDomains : '0'}</p>
            {hasVercelIntegration ? (
                <p class="text-sm text-slate-500 font-medium relative z-10">Aliases únicos rooteados pra Vercel</p>
            ) : (
                <p class="text-sm text-slate-500 relative z-10">---</p>
            )}
        </div>
    </div>

    {/* Seção Secundária: Logs Rápido e CMS Rápidos */}
    {hasVercelIntegration && (
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-10">
            <!-- Timeline de Deploys Globais -->
            <div class="lg:col-span-2 bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="font-bold text-slate-800 flex items-center gap-2">
                        <span class="text-xl">⏱️</span> Atividade Recente
                    </h3>
                    <a href="/dashboard/sites" class="text-sm font-semibold text-violet-600 hover:text-violet-700">Ver Sites &rarr;</a>
                </div>
                
                {globalDeployments.length === 0 ? (
                     <div class="py-6 text-center text-sm text-slate-500 bg-slate-50 rounded-xl border border-slate-100">
                         Nenhum deploy disparado recentemente.
                     </div>
                ) : (
                    <div class="relative pl-6 space-y-6">
                        <!-- Linha Pescadora -->
                        <div class="absolute left-[11px] top-2 bottom-2 w-0.5 bg-slate-100"></div>
                        
                        {globalDeployments.map((dep: any) => {
                            const isReady = dep.readyState === 'READY';
                            const isError = dep.readyState === 'ERROR';
                            const bgIndicator = isReady ? 'bg-emerald-500' : (isError ? 'bg-red-500' : 'bg-amber-500 ring-4 ring-amber-100/50 blink');
                            const timeAgo = new Date(dep.createdAt).toLocaleString('pt-BR', { day: '2-digit', month: 'short', hour: '2-digit', minute: '2-digit' });

                            return (
                                <div class="relative">
                                    <div class={`absolute -left-[30px] top-1.5 w-3 h-3 rounded-full border-2 border-white ring-2 ring-slate-100 ${bgIndicator}`}></div>
                                    <div class="flex items-start justify-between">
                                        <div>
                                            <p class="font-semibold text-slate-800 text-sm mb-0.5">
                                                Novo Deploy <span class="font-normal text-slate-500">em</span> {dep.name}
                                            </p>
                                            <p class="text-xs text-slate-500 font-medium">Conta: {dep._accountName}</p>
                                        </div>
                                        <div class="text-right">
                                            <span class="text-xs font-bold text-slate-400 bg-slate-100 px-2 py-1 rounded-lg inline-block mb-1">
                                                {timeAgo}
                                            </span>
                                            {isReady && dep.url && (
                                                <a href={`https://${dep.url}`} target="_blank" class="block text-xs font-medium text-violet-600 hover:underline">Testar Link</a>
                                            )}
                                        </div>
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                )}
            </div>

            <!-- Atalhos Rápidos para CMS -->
            <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm flex flex-col">
                <h3 class="font-bold text-slate-800 flex items-center gap-2 mb-6">
                    <span class="text-xl">⚡</span> Acesso ao Painel CMS
                </h3>
                
                {allProjects.length === 0 ? (
                    <div class="flex-1 flex items-center justify-center p-6 bg-slate-50 rounded-xl border border-slate-100">
                        <p class="text-sm font-medium text-slate-500 text-center">Nenhum site online para acessar o CMS.</p>
                    </div>
                ) : (
                    <div class="space-y-3 flex-1">
                        {allProjects.slice(0, 4).map((proj: any) => {
                            const prodAlias = proj.alias?.find((a: any) => a.target === 'PRODUCTION' || a.isDefault)?.domain;
                            const domain = prodAlias || proj.alias?.[0]?.domain || `${proj.name}.vercel.app`;
                            return (
                                <a href={`https://${domain}/admin`} target="_blank" class="block p-4 rounded-xl border border-slate-200 hover:border-violet-300 hover:shadow-sm hover:ring-2 hover:ring-violet-50 transition-all group bg-slate-50 hover:bg-white">
                                    <div class="flex justify-between items-center">
                                        <div>
                                            <p class="font-bold text-slate-800 text-sm group-hover:text-violet-700 transition-colors mb-0.5">{proj.name}</p>
                                            <p class="text-xs text-slate-400 font-medium">{domain}</p>
                                        </div>
                                        <div class="w-8 h-8 rounded-full bg-white border border-slate-200 shadow-sm flex items-center justify-center text-slate-400 group-hover:text-violet-600 group-hover:bg-violet-50 transition-colors">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                                        </div>
                                    </div>
                                </a>
                            );
                        })}
                    </div>
                )}
            </div>
        </div>
    )}

    <!-- Lista de Projetos (Exclusivo se tiver Token) -->
    {hasVercelIntegration && (
        <div>
            <h3 class="text-xl font-bold text-slate-800 mb-5">Sites Ativos</h3>
            
            {allProjects.length === 0 ? (
                <div class="bg-slate-50 rounded-2xl border border-dashed border-slate-300 p-10 text-center">
                    <p class="text-slate-500 font-medium mb-4">Nenhum site encontrado nas suas contas Vercel conectadas.</p>
                    <a href="/dashboard/create-site" class="inline-block px-5 py-2 bg-white border border-slate-300 text-slate-700 font-medium rounded-xl hover:bg-slate-50 transition-colors">
                        Criar meu primeiro site
                    </a>
                </div>
            ) : (
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
                    {allProjects.map((proj: any) => {
                        const prodAlias = proj.alias?.find((a: any) => a.target === 'PRODUCTION' || a.isDefault)?.domain;
                        const domain = prodAlias || proj.alias?.[0]?.domain || `${proj.name}.vercel.app`;
                        const statusColor = proj.latestDeployments?.[0]?.readyState === 'READY' ? 'bg-emerald-500' : 'bg-amber-500';
                        const adminUrl = `https://${domain}/admin`;

                        return (
                            <div class="bg-white rounded-2xl border border-slate-200 p-6 shadow-sm hover:shadow-md transition-shadow group flex flex-col justify-between">
                                <div>
                                    <div class="flex items-start justify-between mb-4">
                                        <div>
                                            <div class="flex items-center gap-2 mb-1">
                                                <h4 class="font-bold text-lg text-slate-800">{proj.name}</h4>
                                                <span class="flex items-center gap-1.5 px-2 py-0.5 rounded-full bg-slate-100 text-xs font-medium text-slate-600 border border-slate-200">
                                                    <span class={`w-1.5 h-1.5 rounded-full ${statusColor}`}></span>
                                                    {proj.framework === 'astro' ? 'Astro CSR' : 'CMS'}
                                                </span>
                                            </div>
                                            <a href={`https://${domain}`} target="_blank" rel="noopener noreferrer" class="text-sm text-violet-600 hover:text-violet-700 hover:underline flex items-center gap-1">
                                                {domain}
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor"><path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z" /><path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z" /></svg>
                                            </a>
                                        </div>
                                        <div class="p-2 bg-slate-50 rounded-lg text-slate-400 group-hover:bg-violet-50 group-hover:text-violet-600 transition-colors">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
                                        </div>
                                    </div>
                                    <div class="mb-4">
                                        <p class="text-xs text-slate-500">
                                            Integração: <span class="font-medium text-slate-600">{proj._accountName}</span>
                                        </p>
                                    </div>
                                </div>
                                <div class="pt-4 border-t border-slate-100 flex gap-3">
                                    <a href={adminUrl} target="_blank" rel="noopener noreferrer" class="flex-1 text-center py-2 bg-slate-800 text-white text-sm font-semibold rounded-lg hover:bg-slate-900 transition-colors">
                                        Entrar no CMS
                                    </a>
                                    <a href={`https://vercel.com/dashboard`} target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-white border border-slate-300 text-slate-600 text-sm font-semibold rounded-lg hover:bg-slate-50 transition-colors">
                                        Vercel
                                    </a>
                                </div>
                            </div>
                        );
                    })}
                </div>
            )}
        </div>
    )}
</DashboardLayout>
