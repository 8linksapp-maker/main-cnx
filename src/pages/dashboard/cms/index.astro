---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { supabaseSSR } from '../../../lib/supabaseSSR';

const supabase = supabaseSSR(Astro);
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/login');
}

const { data: sites, error } = await supabase
    .from('sites_cms')
    .select('*')
    .eq('user_id', user.id)
    .order('created_at', { ascending: false });
---

<DashboardLayout title="Projetos IA | CNX">

    <!-- Page Header -->
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-1">Projetos IA</h2>
            <p class="text-sm text-slate-600 font-medium">Gerencie o conteúdo dos sites gerados por inteligência artificial.</p>
        </div>
        <a href="/dashboard/cms/new" class="inline-flex items-center gap-2 px-4 py-2 bg-violet-600 text-white text-sm font-semibold rounded-lg hover:bg-violet-700 transition-colors shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" /></svg>
            Novo Site
        </a>
    </div>

    <!-- Error -->
    {error && (
        <div class="mb-6 bg-red-50 border border-red-100 rounded-xl p-4 text-red-600 text-sm font-medium">
            {error.message}
        </div>
    )}

    <!-- Grid de Sites -->
    {!sites || sites.length === 0 ? (
        <!-- Empty State -->
        <div class="border border-dashed border-slate-200 rounded-xl p-16 text-center bg-white">
            <div class="w-12 h-12 rounded-xl bg-violet-50 flex items-center justify-center mx-auto mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-violet-500"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            </div>
            <h3 class="text-base font-bold text-slate-800 mb-1">Nenhum projeto ainda</h3>
            <p class="text-sm text-slate-400 mb-6 max-w-xs mx-auto">Crie seu primeiro site gerado por IA para começar a gerenciar o conteúdo aqui.</p>
            <a href="/dashboard/cms/new" class="inline-flex items-center gap-2 px-4 py-2 bg-violet-600 text-white text-sm font-semibold rounded-lg hover:bg-violet-700 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" /></svg>
                Criar Primeiro Site
            </a>
        </div>
    ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {sites.map((site) => (
                <div class="bg-white rounded-xl border border-slate-100 hover:border-violet-200 hover:shadow-md hover:shadow-violet-500/5 transition-all duration-200 flex flex-col overflow-hidden group">
                    <!-- Card Body -->
                    <div class="p-5 flex-1">
                        <div class="flex items-start justify-between mb-4">
                            <!-- Avatar -->
                            <div class="w-9 h-9 rounded-full bg-violet-100 text-violet-600 flex items-center justify-center font-bold text-sm shrink-0">
                                {site.company_name?.charAt(0)?.toUpperCase() || 'S'}
                            </div>
                            <!-- Status Badge -->
                            <span class={`px-2.5 py-1 rounded-full text-xs font-bold uppercase tracking-wider ${
                                site.status === 'published'
                                    ? 'bg-emerald-50 text-emerald-600'
                                    : 'bg-amber-50 text-amber-600'
                            }`}>
                                {site.status === 'published' ? 'ativo' : site.status}
                            </span>
                        </div>

                        <h4 class="text-base font-bold text-slate-900 mb-0.5 group-hover:text-violet-700 transition-colors">
                            {site.company_name}
                        </h4>
                        <p class="text-xs text-slate-400 font-mono truncate mb-4">{site.repo_name}</p>

                        <div class="flex items-center gap-1.5 text-xs text-slate-400 font-medium">
                            <span class="uppercase tracking-wide">{site.site_type}</span>
                            <span class="text-slate-200">·</span>
                            <span>{new Date(site.created_at).toLocaleDateString('pt-BR')}</span>
                        </div>
                    </div>

                    <!-- Card Footer -->
                    <div class="px-5 py-3 border-t border-slate-100 flex items-center justify-between gap-2">
                        <a
                            href={site.url}
                            target="_blank"
                            class="flex items-center gap-1.5 text-xs font-semibold text-slate-400 hover:text-slate-700 transition-colors"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
                            Ver site
                        </a>
                        <a
                            href={`/dashboard/cms/${site.id}`}
                            class="px-3 py-1.5 bg-violet-600 hover:bg-violet-700 text-white text-xs font-bold rounded-lg transition-colors"
                        >
                            Abrir CMS
                        </a>
                    </div>
                </div>
            ))}
        </div>
    )}

</DashboardLayout>
