---
import CmsLayout from '../../../../../layouts/CmsLayout.astro';
import { supabaseSSR } from '../../../../../lib/supabaseSSR';
import AuthorsEditor from '../../../../../components/admin/cms/AuthorsEditor.tsx';

const { id } = Astro.params;
const supabase = supabaseSSR(Astro);
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/login');
}

const { data: site, error: siteError } = await supabase
    .from('sites_cms')
    .select('*')
    .eq('id', id)
    .single();

if (!site || siteError) {
    return Astro.redirect('/dashboard/cms');
}
---

<CmsLayout title={`Autores: ${site.company_name} | CMS`} siteId={id as string} siteName={site.company_name} repoName={site.repo_name}>
    <div class="mb-8 pb-6 border-b border-slate-100">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-1">Equipe</p>
        <h2 class="text-2xl font-bold text-slate-900 mb-1">Equipe Editora</h2>
        <p class="text-sm text-slate-400 max-w-xl">Gerencie os perfis que produzem conteúdo — nomes, biografias e fotos.</p>
    </div>

    <AuthorsEditor client:load siteId={id as string} repoName={site.repo_name} />
</CmsLayout>
