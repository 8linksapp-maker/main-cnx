---
import CmsLayout from '../../../../../layouts/CmsLayout.astro';
import { supabaseSSR } from '../../../../../lib/supabaseSSR';
import { LayoutTemplate, Info, Phone, ArrowRight, ShieldCheck } from 'lucide-react';

const { id } = Astro.params;
const supabase = supabaseSSR(Astro);
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/login');
}

const { data: site, error: siteError } = await supabase
    .from('sites_cms')
    .select('*')
    .eq('id', id)
    .single();

if (!site || siteError) {
    return Astro.redirect('/dashboard/cms');
}

// Futuramente, a leitura das rotas disponíveis pode vir remotamente do Astro. 
// Mas na versão 1.0, simularemos as clássicas.
const basePages = [
    { name: 'Página Inicial (Home)', slug: 'home', icon: LayoutTemplate, status: 'Ativa', color: 'emerald' },
    { name: 'Página Sobre Nós', slug: 'sobre', icon: Info, status: 'Ativa', color: 'emerald' },
    { name: 'Página de Contatos', slug: 'contato', icon: Phone, status: 'Ativa', color: 'emerald' },
    { name: 'Política de Privacidade', slug: 'privacidade', icon: ShieldCheck, status: 'Ativa', color: 'blue' },
    { name: 'Termos de Uso', slug: 'termos', icon: ShieldCheck, status: 'Ativa', color: 'blue' }
];
---

<CmsLayout title={`Páginas: ${site.company_name} | CMS`} siteId={id as string} siteName={site.company_name} repoName={site.repo_name}>
    <div class="mb-8 pb-6 border-b border-slate-100">
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-1">Conteúdo</p>
        <h2 class="text-2xl font-bold text-slate-900 mb-1">Páginas Estruturais</h2>
        <p class="text-sm text-slate-400">Edite os blocos fixos do seu site: Home, Sobre, Contato e páginas legais.</p>
    </div>

    <!-- Tabela de Sub-Páginas -->
    <div class="bg-white rounded-xl border border-slate-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-slate-100">
                        <th class="py-3 px-5 text-[10px] font-semibold text-slate-400 uppercase tracking-widest">Página</th>
                        <th class="py-3 px-5 text-[10px] font-semibold text-slate-400 uppercase tracking-widest">Rota</th>
                        <th class="py-3 px-5 text-[10px] font-semibold text-slate-400 uppercase tracking-widest">Status</th>
                        <th class="py-3 px-5 text-[10px] font-semibold text-slate-400 uppercase tracking-widest text-right">Ação</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    {basePages.map((page) => (
                        <tr class={`hover:bg-violet-50/30 transition-colors group ${page.status !== 'Ativa' ? 'opacity-50' : ''}`}>
                            <td class="py-3.5 px-5">
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-lg bg-violet-50 text-violet-500 flex items-center justify-center shrink-0">
                                        <page.icon className="w-4 h-4"/>
                                    </div>
                                    <div>
                                        <p class="text-sm font-semibold text-slate-800">{page.name}</p>
                                        <p class="text-[11px] text-slate-400">{page.status === 'Ativa' ? 'Editor disponível' : 'Em breve'}</p>
                                    </div>
                                </div>
                            </td>
                            <td class="py-3.5 px-5">
                                <code class="text-xs text-slate-500 bg-slate-50 px-2 py-1 rounded font-mono">
                                    /{page.slug === 'home' ? '' : page.slug}
                                </code>
                            </td>
                            <td class="py-3.5 px-5">
                                {page.status === 'Ativa' ? (
                                    <span class="inline-flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-wider text-emerald-600">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span> Ativa
                                    </span>
                                ) : (
                                    <span class="inline-flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-wider text-slate-400">
                                        <span class="w-1.5 h-1.5 rounded-full bg-slate-300"></span> Em Breve
                                    </span>
                                )}
                            </td>
                            <td class="py-3.5 px-5 text-right">
                                {page.status === 'Ativa' ? (
                                    <a href={`/dashboard/cms/${id}/pages/${page.slug}`} class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-violet-600 hover:bg-violet-700 text-white rounded-lg text-xs font-bold transition-colors">
                                        Editar <ArrowRight className="w-3 h-3" />
                                    </a>
                                ) : (
                                    <span class="text-xs text-slate-300 font-medium">Indisponível</span>
                                )}
                            </td>
                        </tr>
                    ))}
                </tbody>
            </table>
        </div>
    </div>
</CmsLayout>
