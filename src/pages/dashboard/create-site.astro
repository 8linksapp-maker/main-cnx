---
/**
 * create-site.astro
 *
 * Painel da plataforma. Antiga tela de setup, agora o principal serviço da área logada.
 */

import DashboardLayout from '../../layouts/DashboardLayout.astro';
import '@fontsource/inter';
import '@fontsource/outfit';

const VERCEL_DEPLOY_URL = 'https://vercel.com/new/clone?repository-url=https%3A%2F%2Fgithub.com%2F8linksapp-maker%2Fcnx&env=ADMIN_SECRET,GITHUB_TOKEN,GITHUB_OWNER,GITHUB_REPO&envDescription=ADMIN_SECRET%3A%20sua%20senha%20(login%3A%20admin%40admin.com%20%2B%20este%20valor)%20%7C%20GITHUB_TOKEN%3A%20gere%20em%20github.com%2Fsettings%2Ftokens%20marcando%20%22repo%22%20%7C%20GITHUB_OWNER%3A%20seu%20usu%C3%A1rio%20do%20GitHub%20%7C%20GITHUB_REPO%3A%20nome%20do%20projeto%20escolhido%20acima&envLink=https%3A%2F%2Fgithub.com%2F8linksapp-maker%2Fcnx%23-vari%C3%A1veis-de-ambiente&project-name=meu-site-cnx&repository-name=meu-site-cnx';
const GITHUB_TOKEN_URL = 'https://github.com/settings/tokens/new?description=CNX+CMS&scopes=repo';

---

<DashboardLayout title="Criar Site | Main CNX">
    <div class="max-w-4xl mx-auto pb-10">
        <!-- Hero -->
        <section class="mb-10 pt-4">
            <h2 class="font-heading font-bold text-3xl sm:text-4xl text-slate-800 leading-tight mb-3">
                Crie um novo site profissional<br />
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-violet-600 to-fuchsia-600">em poucos cliques</span>
            </h2>
            <p class="text-lg text-slate-600 leading-relaxed">
                Siga o passo a passo abaixo. Cada etapa leva menos de 2 minutos. No final, o algoritmo copiará o CMS limpo direto para o seu repositório.
            </p>
        </section>

        <!-- CTA Principal - Botão Vercel -->
        <section class="mb-12">
            <div class="rounded-2xl bg-gradient-to-br from-violet-500/10 via-fuchsia-500/5 to-transparent border border-violet-200/60 p-8 text-center shadow-xl shadow-violet-500/5">
                <p class="text-sm font-semibold text-violet-600 uppercase tracking-wider mb-2">Deploy Automático</p>
                <h3 class="font-heading font-bold text-xl sm:text-2xl text-slate-800 mb-2">Instanciar Novo Site</h3>
                <p class="text-slate-600 mb-6 max-w-md mx-auto">
                    Clique no botão abaixo para provisionar um CMS otimizado na sua nuvem.
                </p>
                <a
                    href={VERCEL_DEPLOY_URL}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-block hover:opacity-90 transition-opacity"
                >
                    <img src="https://vercel.com/button" alt="Deploy with Vercel" class="h-12 w-auto" />
                </a>
            </div>
        </section>

        <!-- Passos -->
        <section class="space-y-6">
            <h3 class="font-heading font-bold text-xl text-slate-800 mb-6 flex items-center gap-2">
                <span class="w-8 h-8 rounded-lg bg-slate-200 flex items-center justify-center text-sm">📋</span>
                Passo a passo manual
            </h3>

            <!-- Passo 1 -->
            <article class="setup-card">
                <div class="setup-step">1</div>
                <div>
                    <h4 class="font-heading font-bold text-lg text-slate-800 mb-2">Criar contas de infraestrutura</h4>
                    <p class="text-slate-600 mb-4">Você vai precisar do <strong>GitHub</strong> (guarda o código) e da <strong>Vercel</strong> (publica o site). Ambos oferecem planos gratuitos generosos.</p>
                    <div class="flex flex-wrap gap-3">
                        <a href="https://github.com/signup" target="_blank" rel="noopener" class="setup-btn setup-btn-primary">
                            Cadastrar GitHub
                        </a>
                        <a href="https://vercel.com/signup" target="_blank" rel="noopener" class="setup-btn setup-btn-secondary">
                            Cadastrar Vercel
                        </a>
                    </div>
                </div>
            </article>

            <!-- Passo 2 -->
            <article class="setup-card">
                <div class="setup-step">2</div>
                <div>
                    <h4 class="font-heading font-bold text-lg text-slate-800 mb-2">Gerar token no GitHub</h4>
                    <p class="text-slate-600 mb-4">O painel administrativo do CMS salvará os conteúdos em nome deste token. <strong>Gere-o antes de prosseguir com o Deploy.</strong></p>
                    <a href={GITHUB_TOKEN_URL} target="_blank" rel="noopener" class="setup-btn setup-btn-primary inline-flex items-center gap-2">
                        Criar Token
                    </a>
                </div>
            </article>

            <!-- Passo 3 -->
            <article class="setup-card">
                <div class="setup-step">3</div>
                <div>
                    <h4 class="font-heading font-bold text-lg text-slate-800 mb-2">Variáveis de Ambiente exigidas na Vercel</h4>
                    <p class="text-slate-600 mb-4">Ao clicar no botão de Deploy, a Vercel importará o template do CMS. Preencha as chaves assim:</p>
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm border-collapse">
                            <thead>
                                <tr class="border-b border-slate-200">
                                    <th class="text-left py-2 pr-4 font-semibold text-slate-700">O que preencher</th>
                                    <th class="text-left py-2 font-semibold text-slate-700">Exemplo</th>
                                </tr>
                            </thead>
                            <tbody class="text-slate-600">
                                <tr class="border-b border-slate-100"><td class="py-2 pr-4"><code class="text-violet-600">ADMIN_SECRET</code></td><td>Sua senha-mestre para editar o CMS</td></tr>
                                <tr class="border-b border-slate-100"><td class="py-2 pr-4"><code class="text-violet-600">GITHUB_TOKEN</code></td><td>O token que você copiou do passo 2</td></tr>
                                <tr class="border-b border-slate-100"><td class="py-2 pr-4"><code class="text-violet-600">GITHUB_OWNER</code></td><td>Seu usuário do GitHub</td></tr>
                                <tr><td class="py-2 pr-4"><code class="text-violet-600">GITHUB_REPO</code></td><td>O nome que dará ao repositório hoje</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </article>

            <!-- Passo 4 -->
            <article class="setup-card">
                <div class="setup-step">4</div>
                <div>
                    <h4 class="font-heading font-bold text-lg text-slate-800 mb-2">Acesso ao novo painel</h4>
                    <p class="text-slate-600 mb-2">Logo após a Vercel finalizar a construção (takes ~2min), você acessará o seu próprio painel de CMS em: <code class="bg-slate-100 px-2 py-0.5 rounded text-sm">https://[SUBDOMÍNIO-DA-VERCEL]/admin</code></p>
                </div>
            </article>
        </section>
    </div>
</DashboardLayout>

<style>
    .font-heading {
        font-family: 'Outfit', system-ui, sans-serif;
    }
    .setup-card {
        @apply rounded-2xl bg-white border border-slate-200/80 p-6 sm:p-8 shadow-sm hover:shadow-md transition-shadow;
    }
    .setup-card-important {
        @apply border-amber-200 bg-amber-50/30;
    }
    .setup-step {
        @apply w-10 h-10 rounded-xl bg-violet-100 text-violet-600 font-bold flex items-center justify-center text-lg mb-4;
    }
    .setup-step-important {
        @apply bg-amber-100 text-amber-700;
    }
    .setup-btn {
        @apply inline-flex items-center justify-center px-5 py-2.5 rounded-xl font-semibold text-sm transition-all;
    }
    .setup-btn-primary {
        @apply bg-violet-600 text-white hover:bg-violet-700 shadow-md shadow-violet-500/20;
    }
    .setup-btn-secondary {
        @apply bg-white border border-slate-300 text-slate-700 hover:bg-slate-50;
    }
</style>
