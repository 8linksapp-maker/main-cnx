---
/**
 * settings.astro
 *
 * Página de configurações do SaaS. Permite ao usuário colar seu
 * Access Token da Vercel para conectarmos a Visão Geral, além de
 * gerenciar sua conta (ex: atualizar senha).
 */

import DashboardLayout from '../../layouts/DashboardLayout.astro';
import '@fontsource/inter';
import '@fontsource/outfit';
import { supabaseSSR } from '../../lib/supabaseSSR';

// Verifica a sessão logada no lado do Servidor com a lib SSR já pronta.
const supabase = supabaseSSR(Astro);
const { data: { user }, error: authError } = await supabase.auth.getUser();

if (authError || !user) {
    return Astro.redirect('/login');
}

// Buscamos todas as integrações
const { data: integrations, error: integrationsError } = await supabase
    .from('integrations')
    .select('*')
    .eq('user_id', user.id)
    .order('created_at', { ascending: false });

const vercelIntegrations = integrations?.filter((i: any) => i.provider === 'vercel') || [];
const githubIntegrations = integrations?.filter((i: any) => i.provider === 'github') || [];
const openaiIntegrations = integrations?.filter((i: any) => i.provider === 'openai') || [];
const geminiIntegrations = integrations?.filter((i: any) => i.provider === 'gemini') || [];

let successMessage = '';
let errorMessage = '';

// Se vier var ?tab=integracoes da URL do Dropdown Menu Lateral
const queryTab = Astro.url.searchParams.get('tab');
let activeTab = queryTab || 'minha-conta'; // 'minha-conta' ou 'integracoes'


// Se for requisição POST
if (Astro.request.method === "POST") {
    try {
        const data = await Astro.request.formData();
        const action = data.get('action')?.toString();

        if (action === 'update_vercel') {
            activeTab = 'integracoes';
            const vercelToken = data.get('vercel_token')?.toString().trim() || '';
            const accountName = data.get('account_name')?.toString().trim() || 'Conta Padrão';

            // Insere a nova integração na tabela
            const { error: insertError } = await supabase
                .from('integrations')
                .insert({
                    user_id: user.id,
                    provider: 'vercel',
                    token: vercelToken,
                    account_name: accountName
                });

            if (insertError) {
                errorMessage = insertError.message;
            } else {
                successMessage = 'Conta da Vercel conectada com sucesso!';
            }
        } 
        else if (action === 'update_github') {
            activeTab = 'integracoes';
            const githubToken = data.get('github_token')?.toString().trim() || '';
            const accountName = data.get('account_name')?.toString().trim() || 'GitHub';

            const { error: insertError } = await supabase
                .from('integrations')
                .insert({
                    user_id: user.id,
                    provider: 'github',
                    token: githubToken,
                    account_name: accountName
                });

            if (insertError) {
                errorMessage = insertError.message;
            } else {
                successMessage = 'Token do GitHub conectado com sucesso!';
            }
        }
        else if (action === 'update_openai') {
            activeTab = 'integracoes';
            const openaiKey = data.get('openai_key')?.toString().trim() || '';

            const { error: insertError } = await supabase
                .from('integrations')
                .insert({
                    user_id: user.id,
                    provider: 'openai',
                    token: openaiKey,
                    account_name: 'OpenAI API Key'
                });

            if (insertError) {
                errorMessage = insertError.message;
            } else {
                successMessage = 'Chave da OpenAI salva com sucesso!';
            }
        }
        else if (action === 'update_gemini') {
            activeTab = 'integracoes';
            const geminiKey = data.get('gemini_key')?.toString().trim() || '';

            const { error: insertError } = await supabase
                .from('integrations')
                .insert({
                    user_id: user.id,
                    provider: 'gemini',
                    token: geminiKey,
                    account_name: 'Google Gemini Key'
                });

            if (insertError) {
                errorMessage = insertError.message;
            } else {
                successMessage = 'Chave do Google Gemini salva com sucesso!';
            }
        }
        else if (action === 'delete_vercel') {
            activeTab = 'integrations';
            const integrationId = data.get('integration_id')?.toString() || '';

            const { error: deleteError } = await supabase
                .from('integrations')
                .delete()
                .eq('id', integrationId)
                .eq('user_id', user.id); // Segurança extra

            if (deleteError) {
                errorMessage = deleteError.message;
            } else {
                successMessage = 'Integração removida com sucesso.';
            }
        }
        else if (action === 'update_password') {
            activeTab = 'account';
            const newPassword = data.get('new_password')?.toString() || '';
            const confirmPassword = data.get('confirm_password')?.toString() || '';

            if (newPassword !== confirmPassword) {
                errorMessage = 'As senhas não coincidem.';
            } else if (newPassword.length < 6) {
                errorMessage = 'A nova senha deve ter pelo menos 6 caracteres.';
            } else {
                const { error: pwdError } = await supabase.auth.updateUser({
                    password: newPassword
                });

                if (pwdError) {
                    errorMessage = pwdError.message;
                } else {
                    successMessage = 'Sua senha foi atualizada com sucesso!';
                }
            }
        }
        
        // No checkout final, recarregamos as integrações para que a UI reflita a mudança
        const { data: newIntegrations } = await supabase
            .from('integrations')
            .select('*')
            .eq('user_id', user.id)
            .order('created_at', { ascending: false });
        
        if (newIntegrations) {
            vercelIntegrations.length = 0;
            vercelIntegrations.push(...newIntegrations.filter((i: any) => i.provider === 'vercel'));
            githubIntegrations.length = 0;
            githubIntegrations.push(...newIntegrations.filter((i: any) => i.provider === 'github'));
            openaiIntegrations.length = 0;
            openaiIntegrations.push(...newIntegrations.filter((i: any) => i.provider === 'openai'));
            geminiIntegrations.length = 0;
            geminiIntegrations.push(...newIntegrations.filter((i: any) => i.provider === 'gemini'));
        }

    } catch (e: any) {
        errorMessage = e.message || 'Erro inesperado ao salvar';
    }
}
---

<DashboardLayout title="Configurações | Main CNX">
    <div class="pb-10">
        <div class="mb-8">
            <h2 class="text-2xl font-bold text-slate-900 mb-1">Configurações</h2>
            <p class="text-sm text-slate-600 font-medium">Gerencie sua conta e integrações.</p>
        </div>
        
        <!-- Header de Abas -->
        <nav class="flex flex-row gap-1 border-b border-slate-200 mb-8">
            <button 
                class="tab-btn active text-left pb-3 px-3 font-semibold transition-colors border-b-2 text-sm"
                data-target="tab-minha-conta"
            >
                <div class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    <span>Minha Conta</span>
                </div>
            </button>
            <button 
                class="tab-btn text-left pb-3 px-3 font-semibold transition-colors border-b-2 text-sm"
                data-target="tab-integracoes"
            >
                <div class="flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                    <span>Integrações</span>
                </div>
            </button>
        </nav>

        <!-- Área Principal -->
        <div class="bg-white border border-slate-200 shadow-sm rounded-xl p-6 sm:p-8">
            
            {successMessage && (
                <div class="mb-6 text-sm text-emerald-700 bg-emerald-50 border border-emerald-100 rounded-xl p-4 flex gap-2 items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                    {successMessage}
                </div>
            )}

            {errorMessage && (
                <div class="mb-6 text-sm text-red-700 bg-red-50 border border-red-100 rounded-xl p-4 flex gap-2 items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
                    {errorMessage}
                </div>
            )}

            <!-- ABA: MINHA CONTA -->
            <div id="tab-minha-conta" class="tab-content">
                <div class="mb-6 border-b border-slate-100 pb-4">
                    <h3 class="font-bold text-base text-slate-800 mb-1">Dados de Acesso</h3>
                    <p class="text-sm text-slate-400">Gerencie as credenciais com as quais você acessa o painel.</p>
                </div>

                <div class="mb-8">
                    <label class="block text-sm font-semibold text-slate-700 mb-2">E-mail Cadastrado</label>
                    <input 
                        type="email" 
                        value={user.email} 
                        disabled 
                        class="w-full px-4 py-3 bg-slate-100 text-slate-500 border border-slate-200 rounded-xl cursor-not-allowed"
                    >
                    <p class="mt-2 text-xs text-slate-500">O e-mail é fixo e não pode ser alterado por aqui.</p>
                </div>

                <form method="POST" class="space-y-6">
                    <input type="hidden" name="action" value="update_password" />
                    
                    <h4 class="font-bold text-sm text-slate-800 mb-4 border-t border-slate-100 pt-6">Mudar Senha</h4>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label for="new_password" class="block text-sm font-semibold text-slate-700 mb-2">Nova Senha</label>
                            <input 
                                type="password" 
                                id="new_password" 
                                name="new_password" 
                                required
                                class="w-full px-4 py-3 bg-slate-50 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-violet-500 transition-colors"
                            >
                        </div>
                        <div>
                            <label for="confirm_password" class="block text-sm font-semibold text-slate-700 mb-2">Confirme a Senha</label>
                            <input 
                                type="password" 
                                id="confirm_password" 
                                name="confirm_password" 
                                required
                                class="w-full px-4 py-3 bg-slate-50 border border-slate-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-violet-500 transition-colors"
                            >
                        </div>
                    </div>

                    <div class="pt-4 text-right">
                        <button type="submit" class="px-5 py-2 bg-violet-600 text-white text-sm font-bold rounded-lg hover:bg-violet-700 transition-colors">
                            Atualizar Senha
                        </button>
                    </div>
                </form>
            </div>

            <!-- ABA: INTEGRAÇÕES -->
            <div id="tab-integracoes" class="tab-content hidden">
                <div class="mb-6 border-b border-slate-100 pb-4">
                    <h3 class="font-bold text-base text-slate-800 mb-1">Integração com a Vercel</h3>
                    <p class="text-sm text-slate-400 mt-1">Precisamos de permissão para ler seus projetos e listá-los na Visão Geral.</p>
                </div>

                <!-- Lista de Integrações -> Vercel -->
                <div class="mb-8">
                    <h4 class="font-bold text-slate-800 mb-4 text-sm">Contas Conectadas</h4>
                    
                    {vercelIntegrations.length === 0 ? (
                        <div class="p-6 border border-dashed border-slate-300 rounded-xl text-center bg-slate-50 text-slate-500 text-sm">
                            Nenhuma conta da Vercel conectada.
                        </div>
                    ) : (
                        <div class="space-y-3">
                            {vercelIntegrations.map((integration: any) => (
                                <div class="flex items-center justify-between p-4 border border-slate-200 rounded-xl bg-white shadow-sm">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 bg-slate-100 rounded-lg flex items-center justify-center text-slate-800">
                                            <svg class="h-5 w-5 fill-current" viewBox="0 0 512 512"><path d="M256 48l240 416H16z"/></svg>
                                        </div>
                                        <div>
                                            <p class="font-bold text-slate-800 text-sm">{integration.account_name}</p>
                                            <p class="text-xs text-slate-500 tracking-wider">Token: {integration.token.slice(0, 5)}••••</p>
                                        </div>
                                    </div>
                                    <form method="POST">
                                        <input type="hidden" name="action" value="delete_vercel" />
                                        <input type="hidden" name="integration_id" value={integration.id} />
                                        <button type="submit" class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition-colors">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" /></svg>
                                        </button>
                                    </form>
                                </div>
                            ))}
                        </div>
                    )}
                </div>

                <form method="POST" class="bg-slate-50 p-6 rounded-2xl border border-slate-200 mb-12">
                    <input type="hidden" name="action" value="update_vercel" />
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase mb-1">Nome da Conta</label>
                            <input type="text" name="account_name" required placeholder="Ex: Minha Vercel" class="w-full px-4 py-2 bg-white border border-slate-300 rounded-lg text-sm">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase mb-1">Vercel Token</label>
                            <input type="password" name="vercel_token" required placeholder="Token da Vercel" class="w-full px-4 py-2 bg-white border border-slate-300 rounded-lg text-sm font-mono">
                        </div>
                    </div>
                    <div class="mt-4 text-right">
                        <button type="submit" class="px-4 py-2 bg-slate-800 text-white text-sm font-bold rounded-lg hover:bg-black transition-colors">Conectar Vercel</button>
                    </div>
                </form>

                <!-- GITHUB -->
                <div class="mt-12 mb-6 border-b border-slate-100 pb-4">
                    <div class="flex items-center gap-3 mb-1">
                        <span class="p-2 bg-slate-900 rounded-lg text-white">
                            <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.43.372.823 1.102.823 2.222 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                        </span>
                        <h3 class="font-heading font-bold text-xl text-slate-800">Integração com o GitHub</h3>
                    </div>
                    <p class="text-sm text-slate-500 mt-2">Personal Access Token (PAT) para criar os repositórios PBN.</p>
                </div>

                <div class="mb-6">
                    {githubIntegrations.length === 0 ? (
                        <div class="p-4 border border-dashed border-slate-300 rounded-xl text-center bg-slate-50 text-slate-500 text-sm">Nenhuma conta conectada.</div>
                    ) : (
                        <div class="space-y-3">
                            {githubIntegrations.map((i: any) => (
                                <div class="flex items-center justify-between p-3 border border-slate-200 rounded-xl bg-white shadow-sm">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 bg-slate-100 rounded-lg flex items-center justify-center text-slate-600">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                                        </div>
                                        <div>
                                            <p class="font-bold text-slate-800 text-sm">{i.account_name}</p>
                                            <p class="text-xs text-slate-400">Token: {i.token.slice(0, 4)}••••</p>
                                        </div>
                                    </div>
                                    <form method="POST">
                                        <input type="hidden" name="action" value="delete_vercel" />
                                        <input type="hidden" name="integration_id" value={i.id} />
                                        <button type="submit" class="p-1.5 text-red-500 hover:bg-red-50 rounded-lg transition-colors"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" /></svg></button>
                                    </form>
                                </div>
                            ))}
                        </div>
                    )}
                </div>

                <form method="POST" class="bg-slate-50 p-6 rounded-2xl border border-slate-200 mb-12">
                    <input type="hidden" name="action" value="update_github" />
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase mb-1">Nome da Conta (GitHub)</label>
                            <input type="text" name="account_name" required placeholder="Ex: Meu GitHub" class="w-full px-4 py-2 bg-white border border-slate-300 rounded-lg text-sm">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-700 uppercase mb-1">Token PAT (ghp_...)</label>
                            <input type="password" name="github_token" required placeholder="Token do GitHub" class="w-full px-4 py-2 bg-white border border-slate-300 rounded-lg text-sm font-mono">
                        </div>
                    </div>
                    <div class="mt-4 text-right">
                        <button type="submit" class="px-4 py-2 bg-slate-800 text-white text-sm font-bold rounded-lg hover:bg-black transition-colors">Conectar GitHub</button>
                    </div>
                </form>

                <!-- OPENAI -->
                <div class="mt-12 mb-6 border-b border-slate-100 pb-4">
                    <div class="flex items-center gap-3 mb-1">
                        <span class="p-2 bg-emerald-600 rounded-lg text-white">🤖</span>
                        <h3 class="font-heading font-bold text-xl text-slate-800">IA Automática (OpenAI)</h3>
                    </div>
                    <p class="text-sm text-slate-500 mt-2">Chave da API usada para gerar o código e conteúdo.</p>
                </div>

                <div class="mb-6">
                    {openaiIntegrations.length === 0 ? (
                        <div class="p-4 border border-dashed border-slate-300 rounded-xl text-center bg-slate-50 text-slate-500 text-sm">Nenhuma chave cadastrada.</div>
                    ) : (
                        <div class="space-y-3">
                            {openaiIntegrations.map((i: any) => (
                                <div class="flex items-center justify-between p-3 border border-slate-200 rounded-xl bg-white shadow-sm">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 bg-emerald-100 rounded-lg flex items-center justify-center text-emerald-600">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>
                                        </div>
                                        <div><p class="font-bold text-slate-800 text-sm">OpenAI Key</p><p class="text-xs text-slate-400">Key: {i.token.slice(0, 5)}••••</p></div>
                                    </div>
                                    <form method="POST">
                                        <input type="hidden" name="action" value="delete_vercel" />
                                        <input type="hidden" name="integration_id" value={i.id} />
                                        <button type="submit" class="p-1.5 text-red-500 hover:bg-red-50 rounded-lg transition-colors"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" /></svg></button>
                                    </form>
                                </div>
                            ))}
                        </div>
                    )}
                </div>

                <form method="POST" class="bg-slate-50 p-6 rounded-2xl border border-slate-200 mb-12">
                    <input type="hidden" name="action" value="update_openai" />
                    <div>
                        <label class="block text-xs font-bold text-slate-700 uppercase mb-1">OpenAI API Key (sk-...)</label>
                        <input type="password" name="openai_key" required placeholder="Sua chave secreta" class="w-full px-4 py-2 bg-white border border-slate-300 rounded-lg text-sm font-mono">
                    </div>
                    <div class="mt-4 text-right">
                        <button type="submit" class="px-4 py-2 bg-slate-800 text-white text-sm font-bold rounded-lg hover:bg-black transition-colors">Salvar OpenAI</button>
                    </div>
                </form>

                <!-- GEMINI -->
                <div class="mt-12 mb-6 border-b border-slate-100 pb-4">
                    <div class="flex items-center gap-3 mb-1">
                        <span class="p-2 bg-blue-600 rounded-lg text-white">✨</span>
                        <h3 class="font-heading font-bold text-xl text-slate-800">Google Gemini AI</h3>
                    </div>
                    <p class="text-sm text-slate-500 mt-2">Alternativa poderosa para geração de conteúdo e código.</p>
                </div>

                <div class="mb-6">
                    {geminiIntegrations.length === 0 ? (
                        <div class="p-4 border border-dashed border-slate-300 rounded-xl text-center bg-slate-50 text-slate-500 text-sm">Nenhuma chave do Gemini cadastrada.</div>
                    ) : (
                        <div class="space-y-3">
                            {geminiIntegrations.map((i: any) => (
                                <div class="flex items-center justify-between p-3 border border-slate-200 rounded-xl bg-white shadow-sm">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center text-blue-600">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
                                        </div>
                                        <div><p class="font-bold text-slate-800 text-sm">Gemini Key</p><p class="text-xs text-slate-400">Key: {i.token.slice(0, 5)}••••</p></div>
                                    </div>
                                    <form method="POST">
                                        <input type="hidden" name="action" value="delete_vercel" />
                                        <input type="hidden" name="integration_id" value={i.id} />
                                        <button type="submit" class="p-1.5 text-red-500 hover:bg-red-50 rounded-lg transition-colors"><svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" /></svg></button>
                                    </form>
                                </div>
                            ))}
                        </div>
                    )}
                </div>

                <form method="POST" class="bg-slate-50 p-6 rounded-2xl border border-slate-200">
                    <input type="hidden" name="action" value="update_gemini" />
                    <div>
                        <label class="block text-xs font-bold text-slate-700 uppercase mb-1">Google Gemini API Key</label>
                        <input type="password" name="gemini_key" required placeholder="Sua chave do Gemini" class="w-full px-4 py-2 bg-white border border-slate-300 rounded-lg text-sm font-mono">
                    </div>
                    <div class="mt-4 text-right">
                        <button type="submit" class="px-4 py-2 bg-slate-800 text-white text-sm font-bold rounded-lg hover:bg-black transition-colors">Salvar Gemini Key</button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</DashboardLayout>

<!-- Variável enviada pelo Server pro Client saber qual aba abrir (útil no refresh após POST) -->
<script define:vars={{ initialTab: activeTab }}>
    document.addEventListener('DOMContentLoaded', () => {
        const buttons = document.querySelectorAll('.tab-btn');
        const contents = document.querySelectorAll('.tab-content');

        function activateTab(tabId) {
            // Esconde tudos conteúdos e limpa formato ativo
            contents.forEach(c => c.classList.add('hidden'));
            buttons.forEach(b => {
                b.classList.remove('text-violet-600', 'border-violet-600');
                b.classList.add('text-slate-500', 'border-transparent', 'hover:text-slate-700', 'hover:border-slate-300');
            });

            // Ativa o alvo
            const targetContent = document.getElementById(tabId);
            const targetBtn = document.querySelector(`[data-target="${tabId}"]`);
            
            if (targetContent && targetBtn) {
                targetContent.classList.remove('hidden');
                targetBtn.classList.remove('text-slate-500', 'border-transparent', 'hover:text-slate-700', 'hover:border-slate-300');
                targetBtn.classList.add('text-violet-600', 'border-violet-600');
            }
        }

        // Event Listeners
        buttons.forEach(btn => {
            btn.addEventListener('click', () => {
                activateTab(btn.getAttribute('data-target'));
            });
        });

        // Inicializa aba correta (vindo do SRR Astro)
        activateTab(`tab-${initialTab}`);
    });
</script>

