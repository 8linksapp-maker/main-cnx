---
/**
 * dashboard/sites/index.astro
 *
 * Página de listagem de todos os projetos Vercel conectados nas
 * contas integradas pelo cliente.
 */
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { supabaseSSR } from '../../../lib/supabaseSSR';

// Verifica a sessão logada e metadados
const supabase = supabaseSSR(Astro);
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
    return Astro.redirect('/login');
}

// Resgatar as Integrações da Vercel
const { data: vercelIntegrations } = await supabase
    .from('integrations')
    .select('*')
    .eq('user_id', user.id)
    .eq('provider', 'vercel');

let allProjects: any[] = [];
let accountErrors: string[] = [];
let hasVercelIntegration = vercelIntegrations && vercelIntegrations.length > 0;

if (hasVercelIntegration) {
    const fetchPromises = vercelIntegrations!.map(async (integration: any) => {
        try {
            const vRes = await fetch('https://api.vercel.com/v9/projects?limit=100', {
                headers: {
                    "Authorization": `Bearer ${integration.token}`
                }
            });
            
            if (!vRes.ok) {
                accountErrors.push(`Token inválido ou acesso negado na integração: ${integration.account_name || 'Conta Vercel'}`);
                return [];
            }
            const data = await vRes.json();
            // Adicionamos o ID interno da integração e o nome no projeto para usarmos caso precise na "details route"
            return (data.projects || []).map((p: any) => ({ 
                ...p, 
                _accountName: integration.account_name,
                _integrationId: integration.id
            }));
        } catch (e: any) {
             accountErrors.push(`Falha de conexão na integração: ${integration.account_name || 'Conta Vercel'}`);
             return [];
        }
    });

    const results = await Promise.all(fetchPromises);
    allProjects = results.flat();
    
    // Opcional: Ordenar por nome ou data
    allProjects.sort((a, b) => b.updatedAt - a.updatedAt);
}
---

<DashboardLayout title="Meus Sites | Main CNX">
    <!-- Page Header -->
    <div class="mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h2 class="text-2xl font-bold text-slate-900 mb-1">Projetos Vercel</h2>
            <p class="text-sm text-slate-600 font-medium">Gerencie todos os seus domínios e projetos integrados da Vercel.</p>
        </div>
        <a href="/dashboard/create-site" class="inline-flex items-center gap-2 px-4 py-2 bg-violet-600 text-white text-sm font-semibold rounded-lg hover:bg-violet-700 transition-colors shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" /></svg>
            Novo Site
        </a>
    </div>

    {/* Alertas */}
    {!hasVercelIntegration && (
        <div class="mb-8 bg-amber-50 border border-amber-200 rounded-xl p-5">
            <h3 class="font-bold text-amber-800 text-sm mb-1">Acesso Necessário</h3>
            <p class="text-amber-700 text-sm mb-3">Você ainda não conectou nenhuma conta da Vercel.</p>
            <a href="/dashboard/settings" class="inline-block px-4 py-1.5 bg-amber-100 font-semibold text-amber-800 text-sm rounded-lg hover:bg-amber-200 transition-colors border border-amber-200">
                Conectar Conta
            </a>
        </div>
    )}

    {accountErrors.length > 0 && (
        <div class="mb-8 space-y-2">
            {accountErrors.map(err => (
                <div class="bg-red-50 border border-red-100 rounded-xl p-4 text-red-700 text-sm font-medium flex gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
                    {err}
                </div>
            ))}
        </div>
    )}

    <!-- Lista Completa de Sites -->
    {hasVercelIntegration && (
        <div>
            {allProjects.length === 0 ? (
                <div class="bg-white rounded-xl border border-dashed border-slate-200 p-12 text-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 mx-auto mb-4"><circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    <h3 class="text-base font-bold text-slate-700 mb-2">Nenhum Projeto Encontrado</h3>
                    <p class="text-slate-400 font-medium text-sm mb-6">As suas conexões com a Vercel estão vazias.</p>
                    <a href="/dashboard/create-site" class="inline-block px-5 py-2 bg-white border border-slate-200 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-50 transition-colors">
                        Deploiar Meu Primeiro Site
                    </a>
                </div>
            ) : (
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                    <ul class="divide-y divide-slate-100">
                        {allProjects.map((proj: any) => {
                            const prodAlias = proj.alias?.find((a: any) => a.target === 'PRODUCTION' || a.isDefault)?.domain;
                            const domain = prodAlias || proj.alias?.[0]?.domain || `${proj.name}.vercel.app`;
                            const deployState = proj.latestDeployments?.[0]?.readyState || 'UNKNOWN';
                            const isReady = deployState === 'READY';
                            const isError = deployState === 'ERROR';
                            const isBuilding = deployState === 'BUILDING';
                            
                            let statusColor = 'bg-slate-400';
                            let statusText = 'Desconhecido';
                            
                            if (isReady) { statusColor = 'bg-emerald-500'; statusText = 'Online'; }
                            else if (isError) { statusColor = 'bg-red-500'; statusText = 'Falha'; }
                            else if (isBuilding) { statusColor = 'bg-amber-500 animate-pulse'; statusText = 'Building'; }

                            return (
                                <li>
                                    <a href={`/dashboard/sites/${proj.id}?integration=${proj._integrationId}`} class="flex flex-col sm:flex-row sm:items-center justify-between p-4 sm:p-5 hover:bg-slate-50 transition-colors group">
                                        <div class="flex items-center gap-4 mb-4 sm:mb-0">
                                            <div class="w-10 h-10 bg-slate-100 rounded-lg flex items-center justify-center text-slate-400 group-hover:bg-violet-100 group-hover:text-violet-600 transition-colors shrink-0">
                                                <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
                                            </div>
                                            <div>
                                                <div class="flex items-center gap-2 mb-0.5">
                                                    <h4 class="font-bold text-sm text-slate-800 group-hover:text-violet-700 transition-colors">{proj.name}</h4>
                                                    <span class="flex items-center gap-1 px-2 py-0.5 rounded-full bg-slate-100 text-xs font-medium text-slate-500 border border-slate-200">
                                                        <span class={`w-1.5 h-1.5 rounded-full ${statusColor}`}></span>
                                                        {statusText}
                                                    </span>
                                                </div>
                                                <p class="text-xs text-slate-400 font-mono">{domain}</p>
                                            </div>
                                        </div>
                                        
                                        <div class="flex items-center gap-6 sm:pl-4 sm:border-l border-slate-200 sm:ml-4">
                                            <div class="hidden md:block text-right">
                                                <p class="text-xs text-slate-400 uppercase font-bold tracking-wider mb-1">Conexão</p>
                                                <p class="text-sm font-medium text-slate-700">{proj._accountName}</p>
                                            </div>
                                            <div class="hidden lg:block text-right">
                                                <p class="text-xs text-slate-400 uppercase font-bold tracking-wider mb-1">Framework</p>
                                                <p class="text-sm font-medium text-slate-700">{proj.framework || 'Other'}</p>
                                            </div>
                                            
                                            <div class="flex-1 flex justify-end gap-2 shrink-0">
                                                <span class="px-4 py-2 bg-white border border-slate-200 rounded-lg text-sm font-bold text-slate-600 hover:bg-slate-100 hover:text-slate-900 transition-colors shadow-sm flex items-center gap-2 group-hover:border-slate-300">
                                                    Detalhes
                                                </span>
                                            </div>
                                        </div>
                                    </a>
                                </li>
                            );
                        })}
                    </ul>
                </div>
            )}
        </div>
    )}
</DashboardLayout>
