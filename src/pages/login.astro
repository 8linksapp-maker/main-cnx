---
/**
 * login.astro
 *
 * Página de login do SaaS. Usuários criam conta e entram por aqui usando Supabase.
 */
import '../styles/global.css';
---
<!doctype html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Login | CNX SaaS</title>
</head>
<body class="min-h-screen font-sans antialiased text-slate-800 bg-gradient-to-b from-slate-50 via-white to-slate-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <h2 class="mt-6 text-center text-3xl font-extrabold text-slate-900">
            Acesse sua conta
        </h2>
        <p class="mt-2 text-center text-sm text-slate-600">
            Ou <button id="toggle-mode-btn" class="font-medium text-violet-600 hover:text-violet-500">crie sua conta grátis</button>
        </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
        <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10 border border-slate-200">
            <!-- Form -->
            <form id="auth-form" class="space-y-6">
                <div>
                    <label for="email" class="block text-sm font-medium text-slate-700">Email</label>
                    <div class="mt-1">
                        <input id="email" name="email" type="email" autocomplete="email" required class="appearance-none block w-full px-3 py-2 border border-slate-300 rounded-md shadow-sm placeholder-slate-400 focus:outline-none focus:ring-violet-500 focus:border-violet-500 sm:text-sm">
                    </div>
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium text-slate-700">Senha</label>
                    <div class="mt-1">
                        <input id="password" name="password" type="password" autocomplete="current-password" required class="appearance-none block w-full px-3 py-2 border border-slate-300 rounded-md shadow-sm placeholder-slate-400 focus:outline-none focus:ring-violet-500 focus:border-violet-500 sm:text-sm">
                    </div>
                </div>

                <!-- Error Message Container -->
                <div id="error-message" class="hidden text-sm text-red-600 bg-red-50 p-3 rounded-md border border-red-200"></div>

                <!-- Success Message Container -->
                <div id="success-message" class="hidden text-sm text-emerald-600 bg-emerald-50 p-3 rounded-md border border-emerald-200"></div>

                <div>
                    <button type="submit" id="submit-btn" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-violet-600 hover:bg-violet-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-violet-500 transition-colors">
                        Entrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        import { supabase } from '../lib/supabase';

        let isLoginMode = true;

        const form = document.getElementById('auth-form') as HTMLFormElement;
        const emailInput = document.getElementById('email') as HTMLInputElement;
        const passwordInput = document.getElementById('password') as HTMLInputElement;
        const submitBtn = document.getElementById('submit-btn');
        const toggleBtn = document.getElementById('toggle-mode-btn');
        const errorDiv = document.getElementById('error-message');
        const successDiv = document.getElementById('success-message');

        // Check if user is already logged in
        async function checkSession() {
            const { data } = await supabase.auth.getSession();
            if (data.session) {
                window.location.href = '/dashboard';
            }
        }
        checkSession();

        // UI Toggle Login / Cadastro
        if (toggleBtn) {
            toggleBtn.addEventListener('click', (e) => {
                e.preventDefault();
                isLoginMode = !isLoginMode;
                toggleBtn.textContent = isLoginMode ? "crie sua conta grátis" : "faça login";
                if(submitBtn) submitBtn.textContent = isLoginMode ? "Entrar" : "Criar Conta";
                
                const heading = document.querySelector('h2');
                if(heading) heading.textContent = isLoginMode ? "Acesse sua conta" : "Criar Nova Conta";

                if(errorDiv) errorDiv.classList.add('hidden');
                if(successDiv) successDiv.classList.add('hidden');
            });
        }

        if (form) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                const email = emailInput.value;
                const password = passwordInput.value;
                
                if (submitBtn) {
                    submitBtn.textContent = "Processando...";
                    submitBtn.setAttribute("disabled", "true");
                }

                if(errorDiv) errorDiv.classList.add('hidden');
                if(successDiv) successDiv.classList.add('hidden');

                try {
                    if (isLoginMode) {
                        const { data, error } = await supabase.auth.signInWithPassword({
                            email,
                            password,
                        });
                        if (error) throw error;
                        window.location.href = '/dashboard';
                    } else {
                        const { data, error } = await supabase.auth.signUp({
                            email,
                            password,
                        });
                        if (error) throw error;
                        
                        if (successDiv) {
                            successDiv.textContent = "Contra criada! Verifique seu email ou tente fazer login.";
                            successDiv.classList.remove('hidden');
                        }
                        // Força toggle pro modo login na interface
                        if(toggleBtn) toggleBtn.click(); 
                    }
                } catch (err: any) {
                    if (errorDiv) {
                        errorDiv.textContent = err.message || "Ocorreu um erro temporário.";
                        errorDiv.classList.remove('hidden');
                    }
                } finally {
                    if (submitBtn) {
                        submitBtn.textContent = isLoginMode ? "Entrar" : "Criar Conta";
                        submitBtn.removeAttribute("disabled");
                    }
                }
            });
        }
    </script>
</body>
</html>
