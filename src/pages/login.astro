---
/**
 * login.astro
 *
 * Página de autenticação do SaaS via Supabase.
 */
import Layout from '../layouts/MainLayout.astro';
import '@fontsource/inter';
import '@fontsource/outfit';

// Se já estiver logado, manda pro dashboard
import { supabaseSSR } from '../lib/supabaseSSR';
const supabaseSsr = supabaseSSR(Astro);
const { data: { user } } = await supabaseSsr.auth.getUser();

if (user) {
    return Astro.redirect('/dashboard');
}
---

<Layout title="Entrar | Main Astro">
    <div class="min-h-screen bg-slate-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8 font-sans">
        <div class="sm:mx-auto sm:w-full sm:max-w-md">
            <h1 class="text-center font-bold text-3xl text-violet-600 font-heading">Main Astro</h1>
            <h2 class="mt-6 text-center text-2xl font-black text-slate-800 tracking-tight">
                Entre na sua conta
            </h2>
            <p class="mt-2 text-center text-sm text-slate-600">
                Gerencie seus sites JAMstack com facilidade.
            </p>
        </div>

        <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
            <div class="bg-white py-8 px-4 shadow-xl shadow-slate-200/50 sm:rounded-2xl sm:px-10 border border-slate-200">
                <form class="space-y-6" id="login-form">
                    <div>
                        <label for="email" class="block text-sm font-semibold text-slate-700">E-mail</label>
                        <div class="mt-1">
                            <input id="email" name="email" type="email" autocomplete="email" required 
                                class="appearance-none block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-violet-500 focus:border-violet-500 sm:text-sm transition-all bg-slate-50 focus:bg-white"
                                placeholder="seu@email.com" />
                        </div>
                    </div>

                    <div>
                        <label for="password" class="block text-sm font-semibold text-slate-700">Senha</label>
                        <div class="mt-1">
                            <input id="password" name="password" type="password" autocomplete="current-password" required 
                                class="appearance-none block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-violet-500 focus:border-violet-500 sm:text-sm transition-all bg-slate-50 focus:bg-white"
                                placeholder="••••••••" />
                        </div>
                    </div>

                    <div class="flex items-center justify-between">
                        <div class="text-sm">
                            <a href="/forgot-password" class="font-semibold text-violet-600 hover:text-violet-500">
                                Esqueceu sua senha?
                            </a>
                        </div>
                    </div>

                    <div>
                        <button type="submit" id="submit-btn" 
                            class="w-full flex justify-center py-3 px-4 border border-transparent rounded-xl shadow-lg shadow-violet-500/20 text-sm font-bold text-white bg-violet-600 hover:bg-violet-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-violet-500 transition-all transform hover:scale-[1.01] active:scale-[0.99]">
                            Entrar no Painel
                        </button>
                    </div>
                </form>

                <div id="error-msg" class="mt-4 p-3 rounded-lg bg-red-50 border border-red-200 text-red-700 text-xs font-semibold hidden"></div>
            </div>
            
            <p class="mt-8 text-center text-xs text-slate-400">
                &copy; {new Date().getFullYear()} CNX SaaS — Todos os direitos reservados.
            </p>
        </div>
    </div>
</Layout>

<style>
    .font-heading {
        font-family: 'Outfit', system-ui, sans-serif;
    }
</style>

<script>
    import { supabase } from '../lib/supabase';

    const loginForm = document.getElementById('login-form') as HTMLFormElement;
    const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    loginForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorMsg.classList.add('hidden');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Entrando...';

        const formData = new FormData(loginForm);
        const email = formData.get('email') as string;
        const password = formData.get('password') as string;

        try {
            const { error } = await supabase.auth.signInWithPassword({
                email,
                password,
            });

            if (error) {
                errorMsg.textContent = error.message;
                errorMsg.classList.remove('hidden');
                submitBtn.disabled = false;
                submitBtn.textContent = 'Entrar no Painel';
            } else {
                window.location.href = '/dashboard';
            }
        } catch (err: any) {
            errorMsg.textContent = 'Erro inesperado. Tente novamente.';
            errorMsg.classList.remove('hidden');
            submitBtn.disabled = false;
            submitBtn.textContent = 'Entrar no Painel';
        }
    });
</script>
