---
/**
 * Header.astro (Classic Theme)
 * 
 * Componente de cabeçalho simplificado: Apenas Logo e Login.
 */
---

<header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md border-b border-white/10 bg-black/80">
    <nav class="container mx-auto px-6 h-20 flex items-center justify-between">
        <a href="/" class="text-2xl font-heading font-black tracking-tighter text-white hover:text-primary transition-colors">
            MEU SITE COM IA
        </a>
        
        <div class="flex items-center gap-4">
            <a href="/login" class="px-5 py-2.5 bg-primary text-white font-bold rounded-lg hover:bg-primary/80 transition-all shadow-lg shadow-primary/30">
                Entrar
            </a>
        </div>
    </nav>
</header>
