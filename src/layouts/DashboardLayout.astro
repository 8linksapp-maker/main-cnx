---
/**
 * DashboardLayout.astro
 *
 * Layout base para a área protegida do SaaS.
 */
import '../styles/global.css';

interface Props {
    title?: string;
}

const { title = "Dashboard | CNX SaaS" } = Astro.props;

// Componentes da Sidebar
const navItems = [
    { label: "Visão Geral", icon: "📊", href: "/dashboard" },
    { label: "Meus Sites", icon: "📁", href: "/dashboard/sites" },
    { label: "Criar Site", icon: "✨", href: "/dashboard/create-site" }
];
---
<!doctype html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
</head>
<body class="bg-slate-50 text-slate-900 font-sans min-h-screen">
    <!-- Base App Wrapper -->
    <div class="flex-1 w-full flex flex-col md:flex-row min-h-screen">
        
        <!-- Sidebar -->
        <aside class="w-64 bg-white border-r border-slate-200 hidden md:flex flex-col shrink-0">
            <div class="h-16 flex items-center px-6 border-b border-slate-100">
                <span class="font-bold text-xl text-violet-600">CNX SaaS</span>
            </div>
            <nav class="flex-1 px-4 py-6 space-y-1">
                {navItems.map(item => (
                    <a 
                        href={item.href}
                        class={`flex items-center gap-3 px-3 py-2 rounded-lg transition-colors ${
                            Astro.url.pathname === item.href || (item.href !== '/dashboard' && Astro.url.pathname.startsWith(item.href))
                                ? 'bg-violet-50 text-violet-700 font-medium' 
                                : 'text-slate-600 hover:bg-slate-50 hover:text-slate-900'
                        }`}
                    >
                        <span>{item.icon}</span>
                        <span>{item.label}</span>
                    </a>
                ))}
            </nav>
        </aside>

        <!-- Main Content wrapper -->
        <div class="flex-1 flex flex-col min-w-0">
            <!-- Header (Mobile Toggle & User Profile) -->
            <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-4 sm:px-6">
                <div class="flex items-center gap-4">
                    <button class="md:hidden text-slate-500 hover:text-slate-700">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
                    </button>
                    <h1 class="font-semibold text-lg hidden sm:block">Painel</h1>
                </div>
                
                <div class="relative group flex items-center gap-3">
                    <button class="flex items-center gap-3 py-1.5 pl-3 pr-4 bg-white hover:bg-slate-50 border border-transparent hover:border-slate-200 rounded-full cursor-pointer transition-all">
                        <div class="text-sm text-right hidden lg:block">
                            <p class="font-bold text-slate-700 leading-none" id="user-email-display">Sua Conta</p>
                        </div>
                        <div class="w-9 h-9 rounded-full bg-violet-100 text-violet-600 flex items-center justify-center font-bold text-sm ring-2 ring-white">
                            ⚙️
                        </div>
                    </button>

                    <!-- Dropdown Content (Hover to show) -->
                    <div class="absolute right-0 top-full mt-1 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-right z-50">
                        <div class="bg-white rounded-2xl shadow-xl shadow-slate-200/50 border border-slate-200 overflow-hidden text-left mt-1">
                            <div class="p-3 border-b border-slate-100 bg-slate-50">
                                <p class="text-[11px] font-bold text-slate-500 uppercase tracking-wider px-2">Configurações</p>
                            </div>
                            <div class="p-2 space-y-1">
                                <a href="/dashboard/settings?tab=minha-conta" class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-slate-700 rounded-lg hover:bg-violet-50 hover:text-violet-700 transition-colors">
                                    <span class="text-lg">👤</span> Meu Perfil
                                </a>
                                <a href="/dashboard/settings?tab=integracoes" class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-slate-700 rounded-lg hover:bg-violet-50 hover:text-violet-700 transition-colors">
                                    <span class="text-lg">🔌</span> Integrações Vercel
                                </a>
                            </div>
                            <div class="p-2 border-t border-slate-100">
                                <button id="logout-btn-header" class="w-full flex items-center gap-3 px-3 py-2 text-sm font-bold text-red-600 rounded-lg hover:bg-red-50 transition-colors text-left">
                                    <span class="text-lg">🚪</span> Sair do Painel
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Main Content Area -->
            <main class="flex-1 p-4 sm:p-6 lg:p-8 overflow-y-auto w-full max-w-7xl mx-auto">
                <slot />
            </main>
        </div>
        
    </div>

    <!-- Client-side Logic for Supabase Auth in the Dashboard -->
    <script>
        import { supabase } from '../lib/supabase';

        async function checkAuth() {
            const { data: { session } } = await supabase.auth.getSession();
            if (!session) {
                window.location.href = '/login';
            } else {
                const display = document.getElementById('user-email-display');
                if (display && session.user.email) {
                    display.textContent = session.user.email;
                }
            }
        }

        async function logout() {
            await supabase.auth.signOut();
            window.location.href = '/login';
        }

        const logoutBtn = document.getElementById('logout-btn-header');
        if (logoutBtn) logoutBtn.addEventListener('click', logout);

        // Run check
        checkAuth();
    </script>

    <!-- CNX Global Modals & Toasts UI -->
    
    <!-- 1. Toast Container (Canto Inferior Direito) -->
    <div id="cnx-toast-container" class="fixed bottom-6 right-6 z-[100] flex flex-col gap-3 pointer-events-none"></div>

    <!-- 2. Modal Overlay de Confirmação -->
    <div id="cnx-confirm-modal" class="fixed inset-0 z-[110] bg-slate-900/40 backdrop-blur-sm opacity-0 invisible transition-all duration-200 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl p-6 sm:p-8 max-w-sm w-full transform scale-95 transition-transform duration-200" id="cnx-confirm-box">
            <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center text-red-600 mb-5 mx-auto">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <h3 class="text-xl font-bold text-center text-slate-800 mb-2">Atenção!</h3>
            <p id="cnx-confirm-msg" class="text-slate-600 text-center mb-6 text-sm"></p>
            
            <div class="flex items-center gap-3 w-full">
                <button id="cnx-confirm-cancel" class="flex-1 py-2.5 px-4 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold rounded-xl transition-colors">Cancelar</button>
                <button id="cnx-confirm-accept" class="flex-1 py-2.5 px-4 bg-red-600 hover:bg-red-700 text-white font-semibold rounded-xl transition-colors shadow-lg shadow-red-500/25">Confirmar</button>
            </div>
        </div>
    </div>

    <!-- Script Global de Comportamento Visual -->
    <script>
        // Sistema de Notificações (Toasts / Logos Inferior Direito)
        window.cnxToast = (message, type = 'success') => {
            const container = document.getElementById('cnx-toast-container');
            if (!container) return;

            const isErr = type === 'error';
            const icon = isErr ? '⚠️' : '✅';
            const bgClass = isErr ? 'bg-red-50 border-red-200 text-red-800' : 'bg-emerald-50 border-emerald-200 text-emerald-800';
            
            const toast = document.createElement('div');
            toast.className = `flex items-center gap-3 px-4 py-3 rounded-xl border shadow-lg transform translate-y-8 opacity-0 transition-all duration-300 pointer-events-auto ${bgClass}`;
            toast.innerHTML = `<span class="text-lg">${icon}</span><span class="font-medium text-sm pr-2">${message}</span>`;
            
            container.appendChild(toast);

            // Animate In
            requestAnimationFrame(() => {
                toast.classList.remove('translate-y-8', 'opacity-0');
            });

            // Animate Out // Remove after 4 seconds
            setTimeout(() => {
                toast.classList.add('opacity-0', 'scale-95');
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        };

        // Sistema de Modal Nativo do SaaS (Interromper Forms)
        window.cnxConfirm = (message, onConfirm) => {
            const modal = document.getElementById('cnx-confirm-modal');
            const box = document.getElementById('cnx-confirm-box');
            const msgEl = document.getElementById('cnx-confirm-msg');
            const cancelBtn = document.getElementById('cnx-confirm-cancel');
            const acceptBtn = document.getElementById('cnx-confirm-accept');

            if (!modal || !box || !msgEl || !cancelBtn || !acceptBtn) return;

            msgEl.textContent = message;

            // Mostra Modal
            modal.classList.remove('opacity-0', 'invisible');
            box.classList.remove('scale-95');

            // Cleanup handlers
            const closeAndClean = () => {
                modal.classList.add('opacity-0', 'invisible');
                box.classList.add('scale-95');
                acceptBtn.onclick = null;
                cancelBtn.onclick = null;
            };

            cancelBtn.onclick = () => {
                closeAndClean();
            };

            acceptBtn.onclick = () => {
                closeAndClean();
                if (onConfirm) onConfirm();
            };
        };

        // Leitura de URL para Ativar Toasts baseados no ?success= ou ?error= (Fallback Inteligente Global)
        document.addEventListener('DOMContentLoaded', () => {
            const params = new URLSearchParams(window.location.search);
            const err = params.get('error');
            const suc = params.get('success');

            if (err) {
                window.cnxToast(err, 'error');
            } else if (suc) {
                // Caso queiramos mensagens personalizadas baseadas no Code
                let finalMsg = suc;
                if (suc === 'domain_removed') finalMsg = 'Domínio removido com sucesso.';
                if (suc === 'domain_added') finalMsg = 'Domínio adicionado com sucesso.';
                if (suc.includes('Dominio Editado')) finalMsg = 'Alvo do domínio alterado.';
                window.cnxToast(finalMsg, 'success');
            }

            if (err || suc) {
                // Limpa os parametros sujos da URL pra não repetir no reload do F5
                const url = new URL(window.location.href);
                url.searchParams.delete('error');
                url.searchParams.delete('success');
                window.history.replaceState({}, '', url);
            }
        });
    </script>
</body>
</html>
