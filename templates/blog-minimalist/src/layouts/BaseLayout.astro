---
import SEO from '../components/layout/SEO.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import CookieConsent from '../components/layout/CookieConsent.astro';
import siteConfig from '../data/siteConfig.json';
import '../styles/global.css';

// Auxiliar para converter Hex em RGB para Tailwind
function hexToRgb(hex: string) {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `${r} ${g} ${b}`;
}

const primaryRGB = hexToRgb(siteConfig.theme?.primary || '#0ea5e9');
const primaryDarkRGB = hexToRgb(siteConfig.theme?.primaryDark || siteConfig.theme?.primary || '#0369a1');
const accentRGB = hexToRgb(siteConfig.theme?.accent || '#f59e0b');

const fonts: Record<string, string> = {
  inter: 'family=Inter:wght@300..900',
  outfit: 'family=Outfit:wght@100..900',
  roboto: 'family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900',
  playfair: 'family=Playfair+Display:ital,wght@0,400..900;1,400..900',
  poppins: 'family=Poppins:wght@300;400;500;600;700;900',
  montserrat: 'family=Montserrat:wght@300..900',
  cormorant: 'family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,700',
  lora: 'family=Lora:ital,wght@0,400..700;1,400..700',
  ptserif: 'family=PT+Serif:ital,wght@0,400;0,700;1,400;1,700',
  notoserif: 'family=Noto+Serif:wght@400;700',
  dmsans: 'family=DM+Sans:wght@300..900',
  spacegrotesk: 'family=Space+Grotesk:wght@300..700',
  syne: 'family=Syne:wght@400..800',
  raleway: 'family=Raleway:wght@300..900',
  quicksand: 'family=Quicksand:wght@300..700',
  oswald: 'family=Oswald:wght@300..700',
  bebas: 'family=Bebas+Neue',
  lato: 'family=Lato:wght@300;400;700;900',
  ubuntu: 'family=Ubuntu:wght@300;400;500;700',
  sourceserif: 'family=Source+Serif+4:wght@300..900',
};
const fontName = siteConfig.theme?.font || 'outfit';
const googleFontQuery = fonts[fontName] || fonts['outfit'];

const cssFontFamilyMapping: Record<string, string> = {
  inter: '"Inter", sans-serif',
  outfit: '"Outfit", sans-serif',
  roboto: '"Roboto", sans-serif',
  playfair: '"Playfair Display", serif',
  poppins: '"Poppins", sans-serif',
  montserrat: '"Montserrat", sans-serif',
  cormorant: '"Cormorant Garamond", serif',
  lora: '"Lora", serif',
  ptserif: '"PT Serif", serif',
  notoserif: '"Noto Serif", serif',
  dmsans: '"DM Sans", sans-serif',
  spacegrotesk: '"Space Grotesk", sans-serif',
  syne: '"Syne", sans-serif',
  raleway: '"Raleway", sans-serif',
  quicksand: '"Quicksand", sans-serif',
  oswald: '"Oswald", sans-serif',
  bebas: '"Bebas Neue", sans-serif',
  lato: '"Lato", sans-serif',
  ubuntu: '"Ubuntu", sans-serif',
  sourceserif: '"Source Serif 4", serif',
};
const fontFamily = cssFontFamilyMapping[fontName] || '"Outfit", sans-serif';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const { title, description, image, type } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href={`https://fonts.googleapis.com/css2?${googleFontQuery}&display=swap`} rel="stylesheet">
    <SEO {title} {description} {image} {type} />
    <style define:vars={{ primaryRGB, primaryDarkRGB, accentRGB, fontFamily }}>
      :root {
        --color-primary: var(--primaryRGB);
        --color-primary-dark: var(--primaryDarkRGB);
        --color-accent: var(--accentRGB);
      }
      body {
        font-family: var(--fontFamily), "Inter", "Outfit", sans-serif;
      }
    </style>
  </head>
  <body class="bg-white text-slate-900 font-sans selection:bg-primary-100 selection:text-primary-700">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieConsent />
  </body>
</html>
