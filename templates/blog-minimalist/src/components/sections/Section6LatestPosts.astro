---
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  limit: number;
  btnText: string;
  btnLink: string;
}

const { title, limit, btnText, btnLink } = Astro.props;

// Puxar os posts reais da coleção
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = sortedPosts.slice(0, limit);
---

<section class="py-32 px-4 bg-slate-50 relative overflow-hidden" id="posts">
  <div class="max-w-7xl mx-auto relative z-10">
    <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
      <div>
        <div class="inline-block px-4 py-1 rounded-full bg-accent-100 text-accent-600 font-bold text-xs uppercase mb-6 tracking-widest">
          Novidades
        </div>
        <h2 class="text-4xl md:text-6xl font-black text-slate-900 tracking-tight leading-tight">{title}</h2>
      </div>
      <a href={btnLink} class="px-8 py-4 rounded-2xl bg-white border border-slate-200 text-slate-900 font-bold flex items-center gap-3 hover:bg-slate-50 transition-all shadow-sm">
        {btnText} <span class="text-primary-600">→</span>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {recentPosts.length > 0 && recentPosts.map((post) => (
        <article class="group bg-white rounded-[2.5rem] overflow-hidden shadow-sm border border-slate-100 hover:shadow-2xl hover:shadow-primary-500/10 transition-all duration-500 hover:-translate-y-2">
          <a href={`/blog/${post.slug}`} class="block aspect-[16/10] overflow-hidden bg-slate-100">
            <img 
              src={post.data.heroImage || 'https://images.unsplash.com/photo-1522202176988-66273c2fd55f'} 
              alt={post.data.title} 
              class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" 
            />
          </a>
          <div class="p-10">
            <div class="flex items-center gap-4 mb-6">
              <span class="px-3 py-1 rounded-lg bg-accent-100 text-accent-600 font-bold text-[10px] uppercase tracking-wider">
                {post.data.category || 'Geral'}
              </span>
              <span class="text-slate-400 text-sm font-medium">
                {post.data.pubDate ? new Date(post.data.pubDate).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' }) : ''}
              </span>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 mb-6 group-hover:text-primary-600 transition-colors leading-snug">
              <a href={`/blog/${post.slug}`}>{post.data.title}</a>
            </h3>
            <div class="pt-6 border-t border-slate-50">
              <a href={`/blog/${post.slug}`} class="text-primary-600 font-bold flex items-center gap-2 group-hover:gap-4 transition-all w-max inline-flex">
                Ler Artigo Completo <span>→</span>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
