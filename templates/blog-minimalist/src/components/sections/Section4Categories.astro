---
import * as LucideIcons from 'lucide-react';

interface Category {
  title: string;
  desc: string;
  icon?: string;
  link: string;
}

interface Props {
  title: string;
  items: Category[];
}

const { title, items = [] } = Astro.props;
---

<section class="py-32 px-4 bg-slate-950 text-white relative overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary-500/50 to-transparent"></div>
  
  <div class="max-w-7xl mx-auto text-center relative z-10">
    <h2 class="text-4xl md:text-6xl font-black mb-20 tracking-tight">{title}</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {items.map((item) => {
        const Icon = (LucideIcons as any)[item.icon || 'Tag'] || LucideIcons.Tag;
        return (
          <div class="group p-10 rounded-[2.5rem] bg-white/5 border border-white/10 text-left hover:bg-white/10 transition-all duration-500 hover:-translate-y-2">
            <div class="mb-8 w-14 h-14 rounded-2xl bg-accent-500/20 flex items-center justify-center text-accent-500 group-hover:bg-accent-500 group-hover:text-white transition-colors">
              <Icon size={28} />
            </div>
            <h3 class="text-3xl font-bold mb-4">{item.title}</h3>
            <p class="text-slate-400 mb-8 leading-relaxed text-lg">{item.desc}</p>
            <a href={item.link} class="inline-flex items-center text-white/70 font-bold text-lg group-hover:translate-x-2 group-hover:text-accent-500 transition-all">
              Explorar {item.title} <span class="ml-2">→</span>
            </a>
          </div>
        );
      })}
    </div>
  </div>
</section>
